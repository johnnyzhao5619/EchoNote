{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoNote",
  "version": "3.0.0",
  "identifier": "app.echonote.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EchoNote",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [
        "Frameworks/libllama.dylib",
        "Frameworks/libggml.dylib",
        "Frameworks/libggml-base.dylib",
        "Frameworks/libggml-cpu.dylib",
        "Frameworks/libggml-metal.dylib"
      ]
    }
  }
}
