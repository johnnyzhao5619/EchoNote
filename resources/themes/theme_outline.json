{
  "version": 2,
  "description": "Semantic theme outline contract for all QSS themes.",
  "themes": [
    "light",
    "dark"
  ],
  "sections": [
    {
      "id": "shell",
      "selectors": [
        "QWidget#app_shell",
        "QWidget#top_bar",
        "QLabel#top_bar_brand",
        "QWidget[role=\"app-topbar-tools\"]",
        "QLineEdit#top_bar_search",
        "QLabel#top_bar_hint",
        "QPushButton#top_bar_task_button",
        "QPushButton#top_bar_task_button:hover",
        "QPushButton#top_bar_task_button:disabled",
        "#sidebar",
        "#sidebar QPushButton[role=\"sidebar-nav-button\"]",
        "QWidget#shell_status_bar",
        "QProgressBar[role=\"shell-resource-bar\"]",
        "QProgressBar[role=\"shell-resource-bar\"][state=\"normal\"]::chunk",
        "QProgressBar[role=\"shell-resource-bar\"][state=\"warning\"]::chunk",
        "QProgressBar[role=\"shell-resource-bar\"][state=\"unavailable\"]::chunk"
      ]
    },
    {
      "id": "base_controls",
      "selectors": [
        "QPushButton[variant=\"primary\"]",
        "QPushButton[variant=\"secondary\"]",
        "QPushButton[variant=\"danger\"]",
        "QLineEdit:focus",
        "QComboBox::drop-down",
        "QDateEdit::drop-down",
        "QCheckBox::indicator",
        "QRadioButton::indicator",
        "QProgressBar::chunk",
        "QScrollBar:vertical"
      ]
    },
    {
      "id": "dialog_and_global_actions",
      "selectors": [
        "QPushButton[role=\"dialog-primary-action\"]",
        "QPushButton[role=\"dialog-secondary-action\"]",
        "QPushButton[role=\"dialog-nav-action\"]",
        "QPushButton[role=\"toolbar-secondary-action\"]",
        "QPushButton[role=\"search-nav-action\"]",
        "QPushButton[role=\"search-close-action\"]"
      ]
    },
    {
      "id": "calendar",
      "selectors": [
        "QPushButton[role=\"calendar-view-toggle\"]",
        "QPushButton[role=\"calendar-nav-action\"]",
        "QPushButton[role=\"calendar-utility-action\"]",
        "QPushButton[role=\"calendar-primary-action\"]",
        "QWidget[role=\"event-card\"]",
        "QFrame[role=\"calendar-day-cell\"]"
      ]
    },
    {
      "id": "timeline",
      "selectors": [
        "QPushButton[role=\"timeline-search-action\"]",
        "QLineEdit[role=\"timeline-search-input\"]",
        "QDateEdit[role=\"timeline-filter-control\"]",
        "QComboBox[role=\"timeline-filter-control\"]",
        "QPushButton[role=\"timeline-recording-action\"]",
        "QPushButton[role=\"timeline-secondary-transcribe-action\"]",
        "QPushButton[role=\"timeline-transcript-action\"]",
        "QPushButton[role=\"timeline-translation-action\"]",
        "QLabel[role=\"current-time\"]",
        "QFrame[role=\"current-time-line\"]"
      ]
    },
    {
      "id": "realtime_record",
      "selectors": [
        "QWidget[role=\"realtime-recording-dock\"]",
        "QWidget[role=\"realtime-summary-group\"]",
        "QWidget[role=\"realtime-console-section\"]",
        "QLabel[role=\"realtime-console-section-title\"]",
        "QLabel[role=\"realtime-duration\"]",
        "QPushButton[role=\"realtime-record-action\"]",
        "QToolButton[role=\"realtime-icon-action\"]",
        "QToolButton[role=\"realtime-icon-action\"]:hover",
        "QToolButton[role=\"realtime-icon-action\"]:checked",
        "QComboBox[role=\"realtime-field-control\"]",
        "QDoubleSpinBox[role=\"realtime-field-control\"]",
        "QToolButton[role=\"realtime-floating-toggle\"]",
        "QToolButton[role=\"realtime-floating-toggle\"]:hover",
        "QToolButton[role=\"realtime-floating-toggle\"]:checked",
        "QWidget[role=\"realtime-floating-overlay\"]",
        "QLabel[role=\"realtime-floating-title\"]",
        "QLabel[role=\"realtime-floating-status\"]",
        "QLabel[role=\"realtime-floating-meta\"]",
        "QLabel[role=\"realtime-floating-section-title\"]",
        "QLabel[role=\"realtime-floating-preview\"]",
        "QPushButton[role=\"realtime-floating-action\"]",
        "QPushButton[role=\"realtime-floating-close\"]"
      ]
    },
    {
      "id": "tabs",
      "selectors": [
        "QTabWidget::pane",
        "QTabBar::tab",
        "QTabBar::tab:selected",
        "QTabBar::tab:hover"
      ]
    },
    {
      "id": "settings",
      "selectors": [
        "QListWidget[role=\"settings-nav\"]",
        "QListWidget[role=\"settings-nav\"]::item",
        "QListWidget[role=\"settings-nav\"]::item:hover",
        "QListWidget[role=\"settings-nav\"]::item:selected",
        "QPushButton[role=\"settings-save-action\"]",
        "QPushButton[role=\"settings-cancel-action\"]",
        "QPushButton[role=\"settings-reset-action\"]",
        "QPushButton[role=\"settings-inline-action\"]",
        "QTabWidget[role=\"model-management-tabs\"]::pane",
        "QTabWidget[role=\"model-management-tabs\"] QTabBar::tab",
        "QTabWidget[role=\"model-management-tabs\"] QTabBar::tab:selected",
        "QFrame[role=\"settings-section-card\"]",
        "QWidget[role=\"settings-provider-selector\"]",
        "QFrame[role=\"settings-provider-option\"]",
        "QFrame[role=\"settings-provider-option\"][state=\"selected\"]",
        "QLabel[role=\"settings-provider-title\"]",
        "QLabel[role=\"settings-provider-description\"]",
        "QLabel[role=\"settings-provider-badge\"]",
        "QGroupBox[role=\"settings-config-group\"]",
        "QGroupBox[role=\"settings-config-group-nested\"]"
      ]
    },
    {
      "id": "audio_player",
      "selectors": [
        "QWidget[role=\"audio-player-surface\"]",
        "QWidget[role=\"audio-player-surface\"][state=\"inspector\"]",
        "QLabel[role=\"audio-player-title\"]",
        "QLabel[role=\"audio-player-title\"][state=\"inspector\"]",
        "QLabel[role=\"audio-player-subtitle\"]",
        "QLabel[role=\"audio-player-mode-caption\"]",
        "QPushButton[role=\"audio-player-mode-action\"]",
        "QWidget[role=\"audio-player-transcript-panel\"]",
        "QFrame[role=\"audio-player-divider\"]",
        "QPushButton[role=\"audio-player-primary\"]",
        "QPushButton[role=\"audio-player-primary\"][state=\"inspector\"]",
        "QPushButton[role=\"audio-player-control\"]",
        "QPushButton[role=\"audio-player-control\"][state=\"inspector\"]",
        "QSlider[role=\"audio-player-progress\"]",
        "QSlider[role=\"audio-player-volume\"]",
        "QLabel[role=\"audio-player-time\"]",
        "QLabel[role=\"audio-player-time\"][state=\"inspector\"]",
        "QLabel[role=\"audio-player-transcript-title\"]",
        "QTextEdit[role=\"audio-player-transcript-text\"]",
        "QPushButton[role=\"audio-player-transcript-toggle\"]"
      ]
    },
    {
      "id": "workspace",
      "selectors": [
        "QLabel[role=\"task-entry-badge\"]",
        "QWidget[role=\"workspace-surface\"]",
        "QWidget[role=\"workspace-task-summary\"]",
        "QToolButton[role=\"workspace-view-mode-toggle\"]",
        "QToolButton[role=\"workspace-view-mode-toggle\"]:hover",
        "QToolButton[role=\"workspace-view-mode-toggle\"]:checked",
        "QToolButton[role=\"workspace-header-action\"]",
        "QToolButton[role=\"workspace-header-action\"]:hover",
        "QWidget[role=\"workspace-explorer-header\"]",
        "QLabel[role=\"workspace-context-label\"]",
        "QWidget[role=\"workspace-library-panel\"]",
        "QTreeWidget[role=\"workspace-nav-tree\"]",
        "QTreeWidget[role=\"workspace-nav-tree\"]::branch:closed:has-children",
        "QTreeWidget[role=\"workspace-nav-tree\"]::branch:open:has-children",
        "QWidget[role=\"workspace-editor-panel\"]",
        "QFrame[role=\"workspace-editor-header\"]",
        "QFrame[role=\"workspace-editor-toolbar\"]",
        "QLabel[role=\"workspace-document-title\"]",
        "QTabWidget[role=\"workspace-document-tabs\"]::pane",
        "QTabWidget[role=\"workspace-document-tabs\"] QTabBar::tab",
        "QTabWidget[role=\"workspace-document-tabs\"] QTabBar::tab:selected",
        "QTabWidget[role=\"workspace-document-tabs\"] QTabBar::tab:hover",
        "QMenu[role=\"workspace-tab-menu\"]",
        "QMenu[role=\"workspace-tab-menu\"]::item:selected",
        "QTabWidget[role=\"workspace-asset-tabs\"]::pane",
        "QTabWidget[role=\"workspace-asset-tabs\"] QTabBar::tab",
        "QTabWidget[role=\"workspace-asset-tabs\"] QTabBar::tab:selected",
        "QTabWidget[role=\"workspace-asset-tabs\"] QTabBar::tab:hover",
        "QToolButton[role=\"workspace-tab-action\"]",
        "QToolButton[role=\"workspace-tab-action\"]:hover",
        "QToolButton[role=\"workspace-tab-close\"]",
        "QToolButton[role=\"workspace-tab-close\"]:hover",
        "QPushButton[role=\"workspace-ai-launcher\"]",
        "QPushButton[role=\"workspace-ai-launcher\"]:hover",
        "QWidget[role=\"workspace-ai-popover\"]",
        "QLabel[role=\"workspace-ai-popover-title\"]",
        "QLabel[role=\"workspace-ai-popover-description\"]",
        "QWidget[role=\"workspace-inspector-panel\"]",
        "QWidget[role=\"workspace-inspector-section\"]",
        "QLabel[role=\"workspace-inspector-section-title\"]",
        "QLabel[role=\"workspace-meta-label\"]",
        "QLabel[role=\"workspace-meta-value\"]",
        "QWidget[role=\"workspace-recording-panel\"]",
        "QPushButton[role=\"workspace-ai-action\"]",
        "QLabel[role=\"workspace-placeholder\"]"
      ]
    },
    {
      "id": "batch",
      "selectors": [
        "QFrame[role=\"batch-viewer-toolbar\"]",
        "QPushButton[role=\"batch-viewer-search-action\"]",
        "QPushButton[role=\"batch-viewer-edit-action\"]",
        "QPushButton[role=\"batch-viewer-copy-action\"]",
        "QPushButton[role=\"batch-viewer-export-action\"]",
        "QPushButton[role=\"task-action-start\"]",
        "QPushButton[role=\"task-action-pause\"]",
        "QPushButton[role=\"task-action-cancel\"]",
        "QPushButton[role=\"task-action-delete\"]",
        "QPushButton[role=\"task-action-view\"]",
        "QPushButton[role=\"task-action-export\"]",
        "QPushButton[role=\"task-action-retry\"]"
      ]
    }
  ]
}
